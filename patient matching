def match_patient_to_trial(patient, trial):
    return {
        "age_match": trial["min_age"] <= patient["age"] <= trial["max_age"],
        "condition_match": trial["condition"] in patient["conditions"]
    }
def calculate_score(results):
    total = len(results)
    matched = sum(1 for v in results.values() if v)
    return int((matched / total) * 100)
