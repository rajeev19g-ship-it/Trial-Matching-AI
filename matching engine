# =========================

import streamlit as st
import requests

st.title("Klinixa AI – Trial Matching")

age = st.slider("Age", 0, 100, 30)
condition = st.text_input("Condition", "diabetes")

if st.button("Find Match"):
    patient = {
        "age": age,
        "conditions": [condition]
    }

    trial = {
        "min_age": 18,
        "max_age": 65,
        "condition": "diabetes"
    }

    response = requests.post("http://localhost:8000/match", json={
        "patient": patient,
        "trial": trial
    })

    result = response.json()

    st.write("Match Score:", result["match_score"])
    st.write("Details:", result["details"])
