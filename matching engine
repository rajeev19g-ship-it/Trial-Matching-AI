from fastapi import FastAPI
from app.matching_engine import match_patient_to_trial
from app.scoring import calculate_score

app = FastAPI()

@app.get("/")
def home():
    return {"message": "Klinixa AI is running"}

@app.post("/match")
def match(data: dict):
    patient = data.get("patient")
    trial = data.get("trial")

    results = match_patient_to_trial(patient, trial)
    score = calculate_score(results)

    return {
        "match_score": score,
        "details": results
    }


# =========================
# FILE: app/matching_engine.py
# =========================

def match_patient_to_trial(patient, trial):
    return {
        "age_match": trial["min_age"] <= patient["age"] <= trial["max_age"],
        "condition_match": trial["condition"] in patient["conditions"]
    }


# =========================
# FILE: app/scoring.py
# =========================

def calculate_score(results):
    total = len(results)
    matched = sum(1 for v in results.values() if v)
    return int((matched / total) * 100)


